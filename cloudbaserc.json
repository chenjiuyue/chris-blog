{
  "envId": "lowcode-0gwpl9v4125156ef",
  "functionRoot": "./functions",
  "functions": [
    {
      "name": "blog-toggleLike",
      "timeout": 5,
      "runtime": "Nodejs16.13",
      "handler": "index.main"
    },
    {
      "name": "blog-autoPublish",
      "timeout": 60,
      "runtime": "Nodejs16.13",
      "handler": "index.main",
      "triggers": [
        {
          "name": "daily-publish-trigger",
          "type": "timer",
          "config": "0 0 18 * * * *"
        }
      ]
    }
  ],
  "app": {
    "serviceName": "cli-test",
    "framework": "vite",
    "installCommand": "npm install",
    "buildCommand": "npm run build",
    "outputDir": "dist"
  }
}
